    padding: 8px 16px !important;
    background-color: #EDF0F6 !important;
    border-color: #ddd !important;
    transition: background-color 0.3s ease-in-out !important;
    border-radius: 20px !important;
}


.distribuidor-form input[type=radio] + label::before, .distribuidor-form input[type=checkbox] + label::before {
	display: none !important;
}
  
.distribuidor-form input[type=radio]:checked + label, .distribuidor-form input[type=checkbox]:checked + label, .distribuidor-form input[type=radio]:checked + label, .distribuidor-form input[type=radio] + label:hover, .distribuidor-form input[type=checkbox] + label:hover {
