			.action_button { 
background-color: #ff7f26;
}


.action_button:hover { 
background-color: #ca5f15;
}

.post-head {
	display: none !important;
}
.author-date {
	display: none !important;
}

ul{
	color: black !important;
}

ol {
	color: black !important;
}
#header_cart {
color:white !important;
}
