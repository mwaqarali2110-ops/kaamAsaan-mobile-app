.mfn-free-delivery-info {
	display: none; }

.icon-user-1:before {
    color: white;
    content: '\f061';
}

.icon-bag-fine:before  {
	color: white; }

.mfn-footer-stickymenu ul li a
{
	color: white; }


.mfn-footer-stickymenu {
	display: none !important;
